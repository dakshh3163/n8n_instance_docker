# ── Postgres ──────────────────────────────────────────────────
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=n8n

# ── n8n URLs (update after Render deploy) ─────────────────────
N8N_HOST=your-n8n.onrender.com
N8N_PROTOCOL=https
WEBHOOK_URL=https://your-n8n.onrender.com/

# ── n8n UI login ──────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_strong_password

# ── Encryption key — generate with: openssl rand -hex 32 ──────
N8N_ENCRYPTION_KEY=replace_with_32_byte_hex_string

# ── Timezone ──────────────────────────────────────────────────
TIMEZONE=Asia/Kolkata
